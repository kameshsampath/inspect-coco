# =============================================================================
# inspect-coco Configuration
# =============================================================================
# Copy this file to .env and configure your settings.

# =============================================================================
# SNOWFLAKE CONNECTION
# =============================================================================
# The framework reads credentials from your existing TOML files.
# These env vars control which connection is used and where to find configs.

# Directory containing connections.toml / config.toml (default: ~/.snowflake)
# SNOWFLAKE_HOME=~/.snowflake

# Named connection to use (default: "default" or default_connection_name in TOML)
# SNOWFLAKE_CONNECTION_NAME=default

# Programmatic Access Token (alternative to TOML token field)
# Format: PAT_{ACCOUNT} where ACCOUNT is uppercased account identifier
# PAT_MYORG-MYACCOUNT=your-pat-token-here

# =============================================================================
# EVAL CONFIGURATION
# =============================================================================

# Default model for cortex CLI (optional — uses CLI default if unset)
# INSPECT_COCO_MODEL=claude-sonnet-4-5

# Default timeout for agent execution in seconds (default: 900)
# INSPECT_COCO_TIMEOUT=900
